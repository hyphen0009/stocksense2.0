rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * KIRANALINK SECURITY RULES
     *
     * Core Philosophy: 
     * This ruleset implements a strict Shopkeeper Ownership model. Security is designed around 
     * "Authorization Independence," where the owner's unique ID (shopkeeperId) is denormalized 
     * onto every document in the hierarchy. This allows for high-performance rules that 
     * never require costly 'get()' lookups for parent documents.
     *
     * Data Structure:
     * Data is organized hierarchically under the root /shops/{shopId} collection. All 
     * sub-resources (Products, Sales, SaleItems, and Alerts) are nested under their 
     * respective shop to maintain logical scoping and physical segregation.
     *
     * Key Security Decisions:
     * 1. Strict Ownership: Only the authenticated shopkeeper matching the 'shopkeeperId' 
     *    can read or write data within a shop's tree.
     * 2. Denormalization for Performance: Every document contains 'shopkeeperId' and 'shopId' 
     *    to allow atomic authorization checks.
     * 3. Immutability: Critical relational fields like 'shopkeeperId' and 'shopId' are 
     *    enforced as immutable after creation to prevent data hijacking or cross-shop leakage.
     * 4. Relational Integrity: Rules enforce that the internal document IDs and shop IDs 
     *    match the path parameters provided in the request.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Validates ownership for an existing document during update/delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates ownership for a new document during creation. */
    function isRequestOwner(userId) {
      return request.resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the Shop entity. Controls the root shop profile.
     * @path /shops/{shopId}
     * @allow (create) if auth.uid matches shopkeeperId and document ID matches shopId.
     * @deny (list) if the user attempts to list shops they do not own.
     * @principle Enforces document ownership and path-to-data consistency.
     */
    match /shops/{shopId} {
      allow get: if isOwner(resource.data.shopkeeperId);
      allow list: if isSignedIn() && (resource == null || isOwner(resource.data.shopkeeperId));
      allow create: if isRequestOwner(request.resource.data.shopkeeperId) && request.resource.data.id == shopId;
      allow update: if isExistingOwner(resource.data.shopkeeperId) && request.resource.data.shopkeeperId == resource.data.shopkeeperId;
      allow delete: if isExistingOwner(resource.data.shopkeeperId);

      /**
       * @description Rules for Products within a shop.
       * @path /shops/{shopId}/products/{productId}
       * @allow (get) if the shopkeeperId in the product document matches the user's UID.
       * @deny (create) if the shopId in the data does not match the URL path.
       * @principle Uses denormalized shopkeeperId to ensure authorization independence.
       */
      match /products/{productId} {
        allow get: if isOwner(resource.data.shopkeeperId);
        allow list: if isSignedIn() && (resource == null || isOwner(resource.data.shopkeeperId));
        allow create: if isRequestOwner(request.resource.data.shopkeeperId) && request.resource.data.shopId == shopId;
        allow update: if isExistingOwner(resource.data.shopkeeperId) && request.resource.data.shopkeeperId == resource.data.shopkeeperId;
        allow delete: if isExistingOwner(resource.data.shopkeeperId);
      }

      /**
       * @description Rules for Sales transactions.
       * @path /shops/{shopId}/sales/{saleId}
       * @allow (update) if owner and shopkeeperId remains unchanged.
       * @deny (create) if the shopkeeperId is missing or incorrect.
       * @principle Ensures sales data is only accessible to the shop owner.
       */
      match /sales/{saleId} {
        allow get: if isOwner(resource.data.shopkeeperId);
        allow list: if isSignedIn() && (resource == null || isOwner(resource.data.shopkeeperId));
        allow create: if isRequestOwner(request.resource.data.shopkeeperId) && request.resource.data.shopId == shopId;
        allow update: if isExistingOwner(resource.data.shopkeeperId) && request.resource.data.shopkeeperId == resource.data.shopkeeperId;
        allow delete: if isExistingOwner(resource.data.shopkeeperId);

        /**
         * @description Rules for individual items within a sale.
         * @path /shops/{shopId}/sales/{saleId}/saleItems/{saleItemId}
         * @allow (create) if user owns the shop via denormalized shopkeeperId.
         * @deny (delete) if requested by a user who is not the shop owner.
         * @principle Deeply nested relational integrity through denormalization.
         */
        match /saleItems/{saleItemId} {
          allow get: if isOwner(resource.data.shopkeeperId);
          allow list: if isSignedIn() && (resource == null || isOwner(resource.data.shopkeeperId));
          allow create: if isRequestOwner(request.resource.data.shopkeeperId) && request.resource.data.saleId == saleId;
          allow update: if isExistingOwner(resource.data.shopkeeperId) && request.resource.data.shopkeeperId == resource.data.shopkeeperId;
          allow delete: if isExistingOwner(resource.data.shopkeeperId);
        }
      }

      /**
       * @description Rules for Alerts (e.g., low stock, smart predictions).
       * @path /shops/{shopId}/alerts/{alertId}
       * @allow (update) if the owner is dismissing an alert.
       * @deny (get) if a user tries to access alerts for a shop they do not own.
       * @principle Grants access to automated insights based on shop ownership.
       */
      match /alerts/{alertId} {
        allow get: if isOwner(resource.data.shopkeeperId);
        allow list: if isSignedIn() && (resource == null || isOwner(resource.data.shopkeeperId));
        allow create: if isRequestOwner(request.resource.data.shopkeeperId) && request.resource.data.shopId == shopId;
        allow update: if isExistingOwner(resource.data.shopkeeperId) && request.resource.data.shopkeeperId == resource.data.shopkeeperId;
        allow delete: if isExistingOwner(resource.data.shopkeeperId);
      }
    }
  }
}